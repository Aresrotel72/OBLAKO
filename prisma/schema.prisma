generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ============================================
// ПОКУПАТЕЛИ САЙТА
// ============================================
model Customer {
  id              String    @id @default(cuid())
  phone           String    @unique
  email           String?   @unique
  passwordHash    String
  name            String
  isVerified      Boolean   @default(false)

  // Связь с Client в Чёрном ассистенте (после первой покупки)
  cherniyClientId String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lastLoginAt     DateTime?

  reservations    Reservation[]
  favorites       Favorite[]
  comparisons     Comparison[]
  reviews         Review[]
  notifications   Notification[]

  @@index([phone])
  @@index([email])
  @@map("customers")
}

// ============================================
// БРОНИРОВАНИЯ
// ============================================
model Reservation {
  id                   String            @id @default(cuid())
  customerId           String

  // Связь с Чёрным ассистентом
  cherniyReservationId String?           @unique

  // Snapshot товара
  productId            String            // ID в ЧА
  productName          String
  productPrice         Decimal           @db.Decimal(12, 4)
  productImage         String?
  quantity             Int               @default(1)

  // Статус и сроки
  status               ReservationStatus @default(PENDING)
  expiresAt            DateTime
  confirmedAt          DateTime?
  completedAt          DateTime?
  cancelledAt          DateTime?
  cancelReason         String?

  // Контакт
  contactPhone         String
  contactName          String
  notes                String?

  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  customer             Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([customerId])
  @@index([expiresAt])
  @@map("reservations")
}

enum ReservationStatus {
  PENDING    // Ожидает подтверждения
  CONFIRMED  // Подтверждена
  READY      // Готова к выдаче
  COMPLETED  // Выкуплена
  CANCELLED  // Отменена
  EXPIRED    // Истекла
}

// ============================================
// ИЗБРАННОЕ
// ============================================
model Favorite {
  id          String   @id @default(cuid())
  customerId  String
  productId   String   // ID в ЧА
  productName String
  createdAt   DateTime @default(now())

  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
  @@map("favorites")
}

// ============================================
// СРАВНЕНИЕ
// ============================================
model Comparison {
  id          String   @id @default(cuid())
  customerId  String
  productId   String   // ID в ЧА
  productName String
  categoryId  String
  createdAt   DateTime @default(now())

  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
  @@map("comparisons")
}

// ============================================
// ОТЗЫВЫ
// ============================================
model Review {
  id          String   @id @default(cuid())
  customerId  String
  productId   String   // ID в ЧА

  rating      Int      // 1-5
  title       String?
  content     String

  isApproved  Boolean  @default(false)
  isPublished Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([isPublished])
  @@map("reviews")
}

// ============================================
// ИЗОБРАЖЕНИЯ ТОВАРОВ (локальный кэш)
// ============================================
model ProductImage {
  id          String   @id @default(cuid())
  productId   String   // ID в ЧА
  url         String
  alt         String?
  type        String   @default("photo") // photo, 360, ar-model
  sortOrder   Int      @default(0)
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([productId])
  @@map("product_images")
}

// ============================================
// КЭШ ТОВАРОВ (для SEO и фильтров)
// ============================================
model ProductCache {
  id            String   @id @default(cuid())
  cherniyId     String   @unique // ID в ЧА

  // Основные данные
  name          String
  slug          String   @unique
  description   String?
  price         Decimal  @db.Decimal(12, 4)
  quantity      Int      @default(0)

  // Категоризация
  category      String   // "cases", "accessories", etc.
  categoryId    String
  categoryName  String

  // Для чехлов iPhone
  iphoneModel   String?  // "iPhone 15 Pro Max", "iPhone 14", etc.
  caseType      String?  // "silicone", "leather", "magsafe", "clear"
  caseColor     String?  // "black", "blue", "red", etc.
  brand         String?

  // SEO
  metaTitle       String?
  metaDescription String?

  // Статистика
  viewCount     Int      @default(0)
  reserveCount  Int      @default(0)

  // Синхронизация
  lastSyncAt    DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([slug])
  @@index([category])
  @@index([iphoneModel])
  @@index([caseType])
  @@index([price])
  @@map("product_cache")
}

// ============================================
// УВЕДОМЛЕНИЯ
// ============================================
model Notification {
  id          String           @id @default(cuid())
  customerId  String

  type        NotificationType
  title       String
  message     String
  link        String?

  isRead      Boolean          @default(false)
  readAt      DateTime?

  sentViaTelegram Boolean      @default(false)
  sentViaWhatsApp Boolean      @default(false)

  createdAt   DateTime         @default(now())

  customer    Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, isRead])
  @@map("notifications")
}

enum NotificationType {
  RESERVATION_CONFIRMED
  RESERVATION_READY
  RESERVATION_EXPIRING
  RESERVATION_CANCELLED
  REVIEW_APPROVED
  PROMOTION
  SYSTEM
}

// ============================================
// НАСТРОЙКИ САЙТА
// ============================================
model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}
